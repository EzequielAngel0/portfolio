---
import type { ImageMetadata } from 'astro';
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import Icon from '../components/ui/Icon.astro';
import { getLocaleFromUrl, getAlternates, useTranslations, localizePath, cvPath } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  // Solo el home ES lo activa: detecta idioma del navegador una vez (ADR 0002).
  detectLanguage?: boolean;
  // SEO por pagina (F5, doc 06): imagen OG 1200x630, tipo OG y JSON-LD.
  ogImage?: ImageMetadata;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown>[];
  // La 404 lo apaga: es una pagina unica bilingue sin par ES/EN.
  withAlternates?: boolean;
}

const {
  title,
  description,
  detectLanguage = false,
  ogImage,
  ogType,
  jsonLd,
  withAlternates,
} = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const alternates = getAlternates(Astro.url);
const base = import.meta.env.BASE_URL;
const otherLocale = locale === 'es' ? 'en' : 'es';
const otherHref = alternates[otherLocale];

// Nav del header (doc 04): aria-current por coincidencia exacta de ruta.
// "Inicio" y "Contacto" se ocultan en movil (el logo cubre el inicio y contacto
// es un anchor de scroll) para dejar sitio al boton de CV sin romper los 360px.
const homePath = localizePath('', locale);
const casePath = localizePath('acp', locale);
const navItems = [
  { href: homePath, label: t('nav.home'), path: homePath, mobileHidden: true },
  { href: casePath, label: t('nav.caseStudy'), path: casePath, mobileHidden: false },
  {
    href: `${homePath}#${t('contact.anchor')}`,
    label: t('nav.contact'),
    path: null,
    mobileHidden: true,
  },
];
const currentPath = Astro.url.pathname;

// El nombre se parte para poder ocultar "Angel" solo en pantallas muy angostas.
const [firstName, ...restName] = t('site.title').split(' ');
const lastName = restName.join(' ');
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* CSP (doc 06): origenes restringidos a self + el beacon de Cloudflare
        (ADR 0006), unica pieza de terceros. 'unsafe-inline' porque los scripts
        anti-FOUC son inline por diseno y Astro inlinea scripts/estilos pequenos:
        hashes serian fragiles (doc 06, decision F5). Solo en produccion: en dev,
        Vite inyecta scripts propios. */}
    {
      import.meta.env.PROD && (
        <meta
          http-equiv="Content-Security-Policy"
          content="default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self'; font-src 'self'; connect-src 'self' https://cloudflareinsights.com https://static.cloudflareinsights.com; base-uri 'self'; form-action 'self'"
        />
      )
    }
    {/* La UI del navegador acompana al tema; los hex espejan --paper (tokens.css) */}
    <meta name="theme-color" content="#f6f5f1" />

    {/* Anti-FOUC de tema: corre antes del primer pintado. Claro por defecto (doc 04). */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var theme =
            stored === 'light' || stored === 'dark'
              ? stored
              : window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches
                ? 'dark'
                : 'light';
          document.documentElement.dataset.theme = theme;
          if (theme === 'dark') {
            var meta = document.querySelector('meta[name="theme-color"]');
            if (meta) meta.setAttribute('content', '#121417');
          }
        } catch (e) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>

    {/* Deteccion de idioma: solo home ES, una vez, con guarda anti ping-pong (ADR 0002). */}
    <script is:inline define:vars={{ detectLanguage }}>
      if (detectLanguage) {
        try {
          if (!localStorage.getItem('lang-pref')) {
            var lang = (navigator.language || 'es').toLowerCase();
            if (lang.indexOf('es') !== 0) {
              localStorage.setItem('lang-pref', 'en');
              location.replace(
                ('/en' + location.pathname).replace(/\/{2,}/g, '/') +
                  location.search +
                  location.hash,
              );
            }
          }
        } catch (e) {
          /* sin localStorage: se queda en ES */
        }
      }
    </script>

    <Seo
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      jsonLd={jsonLd}
      withAlternates={withAlternates}
    />

    {/* Favicon de la identidad (F5): SVG tematizado + ICO + apple-touch-icon */}
    <link rel="icon" href={`${base}favicon.ico`} sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <link
      rel="preload"
      href={`${base}fonts/archivo-latin-wght-normal.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>

  <body>
    <a class="skip-link font-mono" href="#main">{t('a11y.skip')}</a>

    <header class="sticky top-0 z-50 border-b border-line bg-paper">
      <div class="mx-auto flex h-14 max-w-page items-center justify-between px-4 sm:px-6">
        <a
          href={homePath}
          class="inline-flex min-h-10 items-center font-mono text-label font-medium tracking-wide uppercase hover:underline hover:underline-offset-[0.35em]"
        >
          <span class="max-[25rem]:hidden">{firstName}&nbsp;</span>{lastName}
        </a>

        <div class="flex items-center gap-2 sm:gap-4">
          <nav aria-label={t('a11y.nav')} class="flex items-center gap-1">
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  aria-current={item.path === currentPath ? 'page' : undefined}
                  class:list={[
                    'inline-flex min-h-10 items-center rounded-xs px-2 font-mono text-label transition-colors duration-150',
                    item.mobileHidden && 'max-sm:hidden',
                    item.path === currentPath
                      ? 'text-ink underline underline-offset-[0.35em]'
                      : 'text-ink-soft hover:text-ink',
                  ]}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>

          <div class="flex items-center gap-2 sm:border-l sm:border-line sm:pl-4">
            {/* Descarga directa del CV (T8, doc 06): declara formato y descarga.
                Icono solo hasta lg (aria-label lo nombra), texto en pantallas
                anchas; mismo lenguaje visual que los toggles, hit area 40x40. */}
            <a
              href={cvPath(locale)}
              download
              aria-label={t('nav.downloadCv')}
              class="inline-flex h-10 min-w-10 items-center justify-center gap-2 rounded-sm border border-line px-2 text-ink transition-[transform,border-color] duration-150 ease-out hover:border-ink/35 active:scale-[0.96]"
            >
              <Icon name="download" size={16} />
              <span class="hidden font-mono text-label font-medium lg:inline">
                {t('nav.downloadCv')}
              </span>
            </a>

            <button
              id="theme-toggle"
              type="button"
              class="grid size-10 place-items-center rounded-sm border border-line text-ink transition-[transform,border-color] duration-150 ease-out hover:border-ink/35 active:scale-[0.96]"
              aria-label={t('a11y.themeToDark')}
              data-label-dark={t('a11y.themeToDark')}
              data-label-light={t('a11y.themeToLight')}
            >
              {/* Estado visual con el vocabulario del sitio: [ ] claro, [*] oscuro */}
              <span aria-hidden="true" class="font-mono text-label"
                >[<span class="hidden dark:inline">*</span><span class="dark:hidden">&nbsp;</span
                >]</span
              >
            </button>

            <a
              href={otherHref}
              hreflang={otherLocale}
              lang={otherLocale}
              class="grid h-10 min-w-10 place-items-center rounded-sm border border-line px-2 font-mono text-label font-medium uppercase transition-[transform,border-color] duration-150 ease-out hover:border-ink/35 active:scale-[0.96]"
              aria-label={t('a11y.switchLang')}
            >
              {otherLocale}
            </a>
          </div>
        </div>
      </div>
    </header>

    <main id="main" class="mx-auto max-w-page px-4 sm:px-6">
      <slot />
    </main>

    <footer class="mx-auto mt-24 max-w-page px-4 pb-10 sm:px-6">
      <p class="border-t border-line pt-4 font-mono text-label text-ink-soft">
        {t('footer.status')}
      </p>
    </footer>

    {/* Toggle de tema: interruptible, persiste en localStorage, sin FOUC */}
    <script>
      const btn = document.getElementById('theme-toggle');
      const root = document.documentElement;
      // Espeja --paper por tema (tokens.css) para la UI del navegador.
      const themeColors: Record<string, string> = { light: '#f6f5f1', dark: '#121417' };
      const syncLabel = (theme: string) => {
        if (!btn) return;
        const next = theme === 'dark' ? 'light' : 'dark';
        const label = next === 'dark' ? btn.dataset.labelDark : btn.dataset.labelLight;
        if (label) btn.setAttribute('aria-label', label);
      };
      syncLabel(root.dataset.theme ?? 'light');
      btn?.addEventListener('click', () => {
        const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        document
          .querySelector('meta[name="theme-color"]')
          ?.setAttribute('content', themeColors[next] ?? themeColors.light!);
        try {
          localStorage.setItem('theme', next);
        } catch (e) {
          /* almacenamiento no disponible: el tema aun cambia en esta sesion */
        }
        syncLabel(next);
      });
    </script>

    {/* Motion GSAP como mejora progresiva (doc 05). El gate evita descargar
        GSAP donde no hay nada que animar (404) o con reduced motion; el import
        dinamico deja motion.ts en su propio chunk. */}
    <script>
      if (
        document.querySelector('[data-boot], [data-reveal]') &&
        !window.matchMedia('(prefers-reduced-motion: reduce)').matches
      ) {
        import('../scripts/motion');
      }
    </script>

    {/* Beacon de Cloudflare Web Analytics (ADR 0006, D7): unica pieza de
        terceros, defer y no bloqueante; el sitio funciona igual sin el. Solo en
        produccion para no registrar visitas de desarrollo. */}
    {
      import.meta.env.PROD && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={'{"token": "6c62f432341546c2b7e12b9ec22453b7"}'}
        />
      )
    }
  </body>
</html>
