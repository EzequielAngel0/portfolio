---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import certData from '../data/certificados.json';
import tagsData from '../data/tags.json';
import emisoresData from '../data/emisores.json';

const base = import.meta.env.BASE_URL;

const tags = tagsData.tags || [];
const emisores = emisoresData.emisores || [];

const tagMap = new Map(tags.map(t => [t.id, t]));
const emisorMap = new Map(emisores.map(e => [e.id, e]));

const colorMap: Record<string, string> = {
  'brand-cyan': 'text-brand-cyan bg-brand-cyan/10 border-brand-cyan/20 group-hover:bg-brand-cyan/20',
  'brand-purple': 'text-brand-purple bg-brand-purple/10 border-brand-purple/20 group-hover:bg-brand-purple/20',
  'brand-blue': 'text-brand-blue bg-brand-blue/10 border-brand-blue/20 group-hover:bg-brand-blue/20',
  'brand-rose': 'text-brand-rose bg-brand-rose/10 border-brand-rose/20 group-hover:bg-brand-rose/20'
};

const formalEducation = [
  {
    title: "Estudios medios superiores en Desarrollo de Software",
    issuer: "CETI Tonalá",
    date: "2026-06",
    url: "",
    tags: ["dev"],
    skills: ["Arquitectura", "IoT", "Lógica"],
    description: "Fundamentos en desarrollo, arquitectura de red, IoT, matrices lógicas y ensamblado de soluciones escalables a nivel local.",
    glowColor: "rgba(59, 130, 246, 0.4)",
    iconColor: "text-brand-blue",
    iconBg: "bg-brand-blue/10",
    border: "border-brand-blue/30"
  },
  {
    title: "Oracle Next Education (ONE) - Tech Foundation",
    issuer: "Oracle / Alura",
    date: "2025-01",
    url: "",
    tags: ["dev"],
    skills: ["Java POO", "Spring", "MySQL", "APIs"],
    description: "Finalización exitosa de la ruta hiperespecializada en Tech Foundation (Back-End) con formación avanzada en ecosistemas empresariales.",
    glowColor: "rgba(244, 63, 94, 0.4)",
    iconColor: "text-brand-rose",
    iconBg: "bg-brand-rose/10",
    border: "border-brand-rose/30"
  }
];

const certificados = certData.certificados;
const certCount = certificados.length;

// Extract unique tags and issuers that actually exist in the certificates
const rawTags = certificados.flatMap(c => c.tags || []);
const uniqueTagIds = [...new Set(rawTags)].filter(Boolean);
const availableTags = tags.filter(t => uniqueTagIds.includes(t.id));

const rawIssuers = certificados.map(c => c.issuer);
const uniqueIssuerIds = [...new Set(rawIssuers)].filter(Boolean);
const availableIssuers = emisores.filter(e => uniqueIssuerIds.includes(e.id));
---

<Layout
  title="Historial de Certificaciones | Angel Barbosa"
  description="Registro de certificaciones, hitos educativos y credenciales en Ingeniería y Back-End."
>
  <Header currentPage="certificados" />

  <main class="min-h-screen relative z-10 pt-24">

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8">
      <div class="card p-6 sm:p-10 relative overflow-hidden group cursor-default" style="--card-glow: rgba(6, 182, 212, 0.3);">
        <div class="absolute -top-10 -right-10 w-96 h-96 bg-brand-cyan/10 rounded-full blur-[80px] pointer-events-none mix-blend-screen group-hover:bg-brand-cyan/20 transition-all"></div>
        <div class="absolute -bottom-10 -left-10 w-64 h-64 bg-brand-purple/10 rounded-full blur-[80px] pointer-events-none mix-blend-screen group-hover:bg-brand-purple/20 transition-all"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
          <div class="max-w-2xl">
            <span class="inline-flex items-center gap-2 rounded-full border border-brand-cyan/20 bg-brand-cyan/10 px-3 py-1 text-[9px] font-mono font-bold uppercase tracking-widest text-brand-cyan mb-4">
              <span class="h-1.5 w-1.5 rounded-full bg-brand-cyan animate-pulse"></span>
              Historial Académico
            </span>
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight text-white mb-3">
              Registro <span class="text-gradient">Educativo</span>
            </h1>
            <p class="text-sm sm:text-base text-zinc-400 font-medium leading-relaxed">
              Auditoría pública de mis competencias. Explora una base de <strong class="text-white bg-white/10 px-2 py-0.5 border border-white/20 rounded mx-1">{certCount}</strong> credenciales verificadas e hitos educativos.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Hitos Educativos Destacados (Formal Education) -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12 relative z-20">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px bg-gradient-to-r from-transparent via-white/20 to-transparent flex-1"></div>
        <h2 class="text-sm font-bold uppercase tracking-widest text-zinc-400">Hitos Educativos Principales</h2>
        <div class="h-px bg-gradient-to-r from-transparent via-white/20 to-transparent flex-1"></div>
      </div>
      
      <div class="grid gap-6 lg:grid-cols-2">
        {formalEducation.map((edu) => (
          <article class={`relative flex flex-col p-6 sm:p-8 rounded-2xl bg-black/20 border ${edu.border} shadow-2xl backdrop-blur-md overflow-hidden group hover:-translate-y-1 transition-all duration-300`}>
            <div class="absolute inset-0 opacity-20 pointer-events-none transition-opacity group-hover:opacity-40" style={`background: radial-gradient(circle at top right, ${edu.glowColor}, transparent 70%);`}></div>
            
            <div class="flex items-start justify-between mb-6 relative z-10">
              <div class="flex items-center gap-3">
                <div class={`p-2 rounded-xl ${edu.iconBg} ${edu.iconColor} ring-1 ring-white/10`}>
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 14l9-5-9-5-9 5 9 5z" />
                    <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                  </svg>
                </div>
                <div>
                  <span class={`text-[10px] font-black uppercase tracking-widest ${edu.iconColor}`}>{edu.issuer}</span>
                  <h3 class="text-lg sm:text-xl font-bold text-white leading-tight">{edu.title}</h3>
                </div>
              </div>
              <span class="text-[10px] font-mono font-bold text-white/70 bg-white/5 border border-white/10 px-2 py-1 rounded shrink-0">{edu.date}</span>
            </div>
            
            <p class="text-zinc-400 text-sm leading-relaxed mb-6 relative z-10 flex-grow">
              {edu.description}
            </p>
            
            <div class="flex flex-wrap gap-2 relative z-10 mt-auto">
              {edu.skills.map(skill => (
                <span class="px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-white bg-white/5 border border-white/10 rounded-full hover:bg-white/10 transition-colors">
                  {skill}
                </span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Main Content: Sidebar + Grid -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 flex flex-col lg:flex-row gap-8 items-start relative z-20" id="certificados-lista">
      
      <!-- Sidebar Filters -->
      <aside class="w-full lg:w-64 shrink-0 flex flex-col gap-6 lg:sticky lg:top-24">
        <div class="flex items-center justify-between lg:hidden mb-2">
          <h2 class="text-lg font-bold text-white">Filtros</h2>
          <button id="mobileFilterToggle" class="p-2 bg-white/5 rounded-lg text-zinc-400 hover:text-white">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
          </button>
        </div>

        <div id="filterSidebar" class="hidden lg:flex flex-col gap-8 bg-black/20 backdrop-blur-xl border border-white/10 p-6 rounded-2xl shadow-xl">
          
          <!-- Search Box -->
          <div class="flex flex-col gap-3">
            <label class="text-[10px] font-bold uppercase tracking-widest text-zinc-500">Buscador</label>
            <div class="relative group">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-zinc-500 group-focus-within:text-brand-cyan transition-colors">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </div>
              <input
                id="searchBox"
                type="search"
                placeholder="Buscar certificado..."
                class="block w-full rounded-xl border border-white/10 bg-black/20 backdrop-blur-md pl-9 pr-3 py-2.5 text-sm text-white placeholder:text-zinc-600 focus:border-brand-cyan/40 focus:bg-white/5 focus:ring-1 focus:ring-brand-cyan/20 transition-all outline-none"
              />
            </div>
          </div>

          <!-- Category Tags -->
          <div class="flex flex-col gap-3">
            <label class="text-[10px] font-bold uppercase tracking-widest text-zinc-500">Categorías</label>
            <div class="flex flex-wrap gap-2">
              <button
                class="filter-chip active:scale-95 inline-flex items-center justify-center rounded-lg px-3 py-1.5 text-xs font-semibold text-zinc-400 hover:text-white bg-white/5 hover:bg-white/10 border border-white/5 transition-all outline-none cursor-pointer w-full text-left justify-start"
                data-filter-category="all"
                aria-pressed="true"
              >
                Todas las categorías
              </button>
              {
                availableTags.map((tag) => (
                  <button
                    class="filter-chip active:scale-95 inline-flex items-center justify-start rounded-lg px-3 py-1.5 text-xs font-semibold text-zinc-400 hover:text-white bg-white/5 hover:bg-white/10 border border-white/5 transition-all outline-none cursor-pointer w-full"
                    data-filter-category={tag.id}
                    aria-pressed="false"
                  >
                    <span class={`w-2 h-2 rounded-full mr-2 ${tagMap.get(tag.id)?.color ? 'bg-' + tagMap.get(tag.id)?.color.replace('brand-', '') + '-400' : 'bg-zinc-500'}`} style={tagMap.get(tag.id)?.color === 'brand-cyan' ? 'background-color: #06b6d4' : tagMap.get(tag.id)?.color === 'brand-purple' ? 'background-color: #a855f7' : tagMap.get(tag.id)?.color === 'brand-blue' ? 'background-color: #3b82f6' : tagMap.get(tag.id)?.color === 'brand-rose' ? 'background-color: #f43f5e' : ''}></span>
                    {tag.name}
                  </button>
                ))
              }
            </div>
          </div>

          <!-- Issuer Dropdown -->
          <div class="flex flex-col gap-3">
            <label class="text-[10px] font-bold uppercase tracking-widest text-zinc-500">Institución</label>
            <div class="relative custom-select" data-id="issuerSelect">
              <button type="button" class="select-trigger w-full flex items-center justify-between bg-black/20 backdrop-blur-md border border-white/10 rounded-xl px-3 py-2.5 text-sm text-zinc-300 hover:border-white/20 transition-colors outline-none focus:border-brand-cyan/40 focus:ring-1 focus:ring-brand-cyan/20">
                <span class="select-value">Todos los Emisores</span>
                <svg class="w-4 h-4 text-zinc-500 pointer-events-none transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </button>
              
              <div class="select-options absolute z-50 w-full mt-2 bg-[#0a0a0f]/95 backdrop-blur-xl border border-white/10 rounded-xl shadow-2xl opacity-0 invisible scale-95 origin-top transition-all duration-200 flex flex-col py-1 max-h-60 overflow-y-auto hide-scrollbar">
                <button type="button" class="select-option w-full text-left px-4 py-2.5 text-sm text-zinc-400 hover:text-white hover:bg-white/10 transition-colors" data-value="all">Todos los Emisores</button>
                {availableIssuers.map(issuer => (
                  <button type="button" class="select-option w-full text-left px-4 py-2.5 text-sm text-zinc-400 hover:text-white hover:bg-white/10 transition-colors" data-value={issuer.id}>{issuer.name}</button>
                ))}
              </div>
            </div>
          </div>

          <!-- Sort Dropdown -->
          <div class="flex flex-col gap-3">
            <label class="text-[10px] font-bold uppercase tracking-widest text-zinc-500">Ordenamiento</label>
            <div class="relative custom-select" data-id="sortSelect">
              <button type="button" class="select-trigger w-full flex items-center justify-between bg-black/20 backdrop-blur-md border border-white/10 rounded-xl px-3 py-2.5 text-sm text-zinc-300 hover:border-white/20 transition-colors outline-none focus:border-brand-cyan/40 focus:ring-1 focus:ring-brand-cyan/20">
                <span class="select-value">Más recientes primero</span>
                <svg class="w-4 h-4 text-zinc-500 pointer-events-none transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </button>
              
              <div class="select-options absolute z-50 w-full mt-2 bg-[#0a0a0f]/95 backdrop-blur-xl border border-white/10 rounded-xl shadow-2xl opacity-0 invisible scale-95 origin-top transition-all duration-200 flex flex-col py-1 max-h-60 overflow-y-auto hide-scrollbar">
                <button type="button" class="select-option w-full text-left px-4 py-2.5 text-sm text-zinc-400 hover:text-white hover:bg-white/10 transition-colors" data-value="desc">Más recientes primero</button>
                <button type="button" class="select-option w-full text-left px-4 py-2.5 text-sm text-zinc-400 hover:text-white hover:bg-white/10 transition-colors" data-value="asc">Más antiguos primero</button>
              </div>
            </div>
          </div>

        </div>
      </aside>

      <!-- Grid Content -->
      <div class="flex-1 w-full">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-sm font-bold text-white"><span id="resultsCount">{certCount}</span> Certificados encontrados</h2>
        </div>

        <div id="certGrid" class="grid gap-4 md:grid-cols-2 xl:grid-cols-3 items-start">
          {
            certificados.map((cert) => {
              const issuerName = emisorMap.get(cert.issuer)?.name || cert.issuer;
              return (
              <article
                class="cert-card flex flex-col p-5 rounded-2xl bg-black/20 backdrop-blur-md border border-white/5 hover:border-brand-cyan/30 hover:bg-white/5 shadow-lg group cursor-default h-full transition-all duration-300 relative overflow-hidden"
                data-tags={(cert.tags || []).join(' ')}
                data-issuer={cert.issuer}
                data-date={cert.date || '1970-01'}
                style="order: 0;"
              >
                <!-- Card Header -->
                <div class="flex items-start justify-between mb-4 relative z-10 gap-2">
                  <div class="flex items-center gap-2.5">
                     <div class="p-1.5 rounded-lg border border-brand-cyan/20 bg-brand-cyan/10 text-brand-cyan group-hover:scale-110 transition-transform">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>
                     </div>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-zinc-500 line-clamp-1" title={issuerName}>{issuerName}</span>
                  </div>
                  {cert.date && (
                    <span class="text-[9px] font-mono font-bold text-zinc-500 bg-white/5 border border-white/5 px-1.5 py-0.5 rounded-md shrink-0">{cert.date}</span>
                  )}
                </div>
                
                <!-- Card Body -->
                <h3 class="font-bold text-white leading-snug mb-4 relative z-10 text-[15px] flex-grow group-hover:text-brand-cyan transition-colors">
                  {cert.title}
                </h3>
                
                <!-- Tags & Skills -->
                <div class="flex flex-col gap-2 relative z-10 mb-5">
                  <!-- Category Tags (Colored) -->
                  {cert.tags && cert.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5">
                      {cert.tags.map(tagId => {
                        const tag = tagMap.get(tagId);
                        if (!tag) return null;
                        const colorClass = colorMap[tag.color] || 'text-zinc-300 bg-white/5 border-white/10';
                        return (
                          <span class={`px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider border rounded-md transition-colors ${colorClass}`}>
                            {tag.name}
                          </span>
                        );
                      })}
                    </div>
                  )}

                  <!-- Standard Skills -->
                  <div class="flex flex-wrap gap-1.5">
                    {(cert.skills || []).slice(0, 3).map((skill) => (
                      <span class="px-2 py-0.5 text-[9px] font-bold tracking-wide text-zinc-400 bg-black/40 border border-white/5 rounded-md group-hover:bg-white/5 transition-colors">
                        {skill}
                      </span>
                    ))}
                    {(cert.skills || []).length > 3 && (
                      <span class="text-[9px] font-mono font-bold text-zinc-600 flex items-center px-1.5 py-0.5 rounded border border-transparent">
                        +{(cert.skills || []).length - 3}
                      </span>
                    )}
                  </div>
                </div>
                
                <!-- Card Footer -->
                <div class="mt-auto border-t border-white/[0.04] pt-4 relative z-10 flex items-center justify-between">
                  {cert.url ? (
                    <a
                      href={cert.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1.5 text-[11px] font-semibold text-brand-cyan hover:text-cyan-400 transition-colors cursor-pointer group/link"
                    >
                      Verificación Segura
                      <svg class="h-3 w-3 group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                    </a>
                  ) : (
                    <div class="flex items-center gap-1.5 text-[11px] font-semibold text-zinc-600 cursor-not-allowed">
                      Emisión en cola
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    </div>
                  )}
                </div>
              </article>
              );
            })
          }
        </div>
        
        <!-- Empty State -->
        <div id="emptyState" class="hidden flex-col items-center justify-center py-20 text-center border border-white/5 rounded-2xl bg-black/20 backdrop-blur-md">
          <div class="w-16 h-16 mb-4 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-zinc-500">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">No se encontraron resultados</h3>
          <p class="text-sm text-zinc-400">Intenta ajustar los filtros o los términos de búsqueda.</p>
          <button id="resetFiltersBtn" class="mt-4 px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-xs font-bold rounded-lg transition-colors">
            Limpiar filtros
          </button>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  
  /* Selected Tab State */
  .filter-chip[aria-pressed="true"] {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.15);
  }
  
  /* Smooth Grid Transitions */
  #certGrid {
    transition: all 0.3s ease-in-out;
  }
</style>

<script>
  // ===== State Management =====
  const state = { 
    category: 'all', 
    issuer: 'all',
    q: '',
    sort: 'desc' // 'desc' or 'asc'
  };

  const grid = document.getElementById('certGrid');
  const emptyState = document.getElementById('emptyState');
  const resultsCountSpan = document.getElementById('resultsCount');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.cert-card'));

  function applyFiltersAndSort() {
    let visibleCount = 0;
    const q = state.q.toLowerCase().trim();

    // 1. Filter
    cards.forEach((card) => {
      const tags = (card.dataset.tags || '').split(/\s+/);
      const issuer = card.dataset.issuer || '';
      
      const matchesCategory = state.category === 'all' || tags.includes(state.category);
      const matchesIssuer = state.issuer === 'all' || issuer === state.issuer;
      
      const text = card.innerText.toLowerCase();
      const matchesSearch = !q || text.includes(q);
      
      if (matchesCategory && matchesIssuer && matchesSearch) {
        card.style.display = 'flex';
        card.classList.add('is-visible');
        visibleCount++;
      } else {
        card.style.display = 'none';
        card.classList.remove('is-visible');
      }
    });

    // 2. Sort visible cards
    const visibleCards = cards.filter(c => c.classList.contains('is-visible'));
    
    visibleCards.sort((a, b) => {
      const dateA = a.dataset.date || '1970-01';
      const dateB = b.dataset.date || '1970-01';
      
      // Compare YYYY-MM
      if (state.sort === 'desc') {
        return dateB.localeCompare(dateA); // Newest first
      } else {
        return dateA.localeCompare(dateB); // Oldest first
      }
    });

    // Apply sorting via flex/grid order
    visibleCards.forEach((card, index) => {
      card.style.order = index.toString();
    });

    // 3. Update UI
    if (resultsCountSpan) resultsCountSpan.innerText = visibleCount.toString();

    if (visibleCount === 0) {
      if (grid) grid.style.display = 'none';
      if (emptyState) emptyState.style.display = 'flex';
    } else {
      if (grid) grid.style.display = 'grid';
      if (emptyState) emptyState.style.display = 'none';
    }
  }

  // ===== Event Listeners =====

  // Mobile Filter Toggle
  const mobileFilterToggle = document.getElementById('mobileFilterToggle');
  const filterSidebar = document.getElementById('filterSidebar');
  mobileFilterToggle?.addEventListener('click', () => {
    filterSidebar?.classList.toggle('hidden');
    filterSidebar?.classList.toggle('flex');
  });

  // Categories
  function setCategory(cat: string) {
    state.category = cat;
    const chips = document.querySelectorAll<HTMLElement>('.filter-chip');
    chips.forEach(c => c.setAttribute('aria-pressed', 'false'));
    const active = Array.from(chips).find(c => c.dataset.filterCategory === cat) || chips[0];
    active?.setAttribute('aria-pressed', 'true');
    applyFiltersAndSort();
  }

  document.querySelectorAll<HTMLElement>('.filter-chip').forEach((ch) => {
    ch.addEventListener('click', () => {
      setCategory(ch.dataset.filterCategory || 'all');
    });
  });

  // Custom Select Logic
  document.querySelectorAll('.custom-select').forEach(select => {
    const trigger = select.querySelector('.select-trigger') as HTMLButtonElement;
    const valueDisplay = select.querySelector('.select-value') as HTMLSpanElement;
    const optionsPanel = select.querySelector('.select-options') as HTMLDivElement;
    const options = select.querySelectorAll('.select-option');
    const id = (select as HTMLElement).dataset.id;
    
    // Toggle dropdown
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      // Close other dropdowns first
      document.querySelectorAll('.select-options.is-open').forEach(panel => {
        if (panel !== optionsPanel) {
          panel.classList.remove('is-open', 'opacity-100', 'visible', 'scale-100');
          panel.classList.add('opacity-0', 'invisible', 'scale-95');
          const siblingTrigger = panel.previousElementSibling as HTMLButtonElement;
          siblingTrigger.querySelector('svg')?.classList.remove('rotate-180');
        }
      });
      
      const isOpen = optionsPanel.classList.contains('is-open');
      if (isOpen) {
        optionsPanel.classList.remove('is-open', 'opacity-100', 'visible', 'scale-100');
        optionsPanel.classList.add('opacity-0', 'invisible', 'scale-95');
        trigger.querySelector('svg')?.classList.remove('rotate-180');
      } else {
        optionsPanel.classList.add('is-open', 'opacity-100', 'visible', 'scale-100');
        optionsPanel.classList.remove('opacity-0', 'invisible', 'scale-95');
        trigger.querySelector('svg')?.classList.add('rotate-180');
      }
    });
    
    // Select option
    options.forEach(option => {
      option.addEventListener('click', (e) => {
        e.stopPropagation();
        const value = (option as HTMLElement).dataset.value;
        const text = (option as HTMLElement).innerText;
        valueDisplay.innerText = text;
        
        optionsPanel.classList.remove('is-open', 'opacity-100', 'visible', 'scale-100');
        optionsPanel.classList.add('opacity-0', 'invisible', 'scale-95');
        trigger.querySelector('svg')?.classList.remove('rotate-180');
        
        // Update state
        if (id === 'issuerSelect') {
          state.issuer = value || 'all';
        } else if (id === 'sortSelect') {
          state.sort = value || 'desc';
        }
        applyFiltersAndSort();
      });
    });
  });

  // Close dropdowns when clicking outside
  document.addEventListener('click', () => {
    document.querySelectorAll('.select-options.is-open').forEach(panel => {
      panel.classList.remove('is-open', 'opacity-100', 'visible', 'scale-100');
      panel.classList.add('opacity-0', 'invisible', 'scale-95');
      const trigger = panel.previousElementSibling as HTMLButtonElement;
      trigger.querySelector('svg')?.classList.remove('rotate-180');
    });
  });

  // Search Box
  const searchBox = document.getElementById('searchBox') as HTMLInputElement;
  searchBox?.addEventListener('input', (e) => {
    state.q = (e.target as HTMLInputElement).value || '';
    applyFiltersAndSort();
  });

  // Reset Button
  const resetBtn = document.getElementById('resetFiltersBtn');
  resetBtn?.addEventListener('click', () => {
    setCategory('all');
    
    state.issuer = 'all';
    const issuerDisplay = document.querySelector('.custom-select[data-id="issuerSelect"] .select-value');
    if (issuerDisplay) issuerDisplay.textContent = 'Todos los Emisores';
    
    state.sort = 'desc';
    const sortDisplay = document.querySelector('.custom-select[data-id="sortSelect"] .select-value');
    if (sortDisplay) sortDisplay.textContent = 'Más recientes primero';
    
    if (searchBox) searchBox.value = '';
    state.q = '';
    applyFiltersAndSort();
  });

  // Initialize
  const sp = new URLSearchParams(location.search);
  const initialCat = (sp.get('category') || sp.get('tag') || 'all').toLowerCase();
  const initialQ = sp.get('q') || '';
  
  if (initialQ && searchBox) {
    searchBox.value = initialQ;
    state.q = initialQ;
  }
  setCategory(initialCat);
  
  // Initial sort
  applyFiltersAndSort();
</script>
