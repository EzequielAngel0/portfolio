---
// Footer — Vibrant Minimalist Technical
const currentYear = new Date().getFullYear();
---

<footer class="relative z-10">
  <div class="divider-gradient mx-auto max-w-5xl mb-0"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 flex flex-col md:flex-row items-center justify-between gap-4">
    
    <p class="text-[10px] font-mono text-zinc-600 tracking-widest uppercase">
      Arquitectura <span class="text-brand-purple/40 mx-1">·</span> 
      Backend <span class="text-brand-cyan/40 mx-1">·</span> 
      Seguridad
    </p>

    <div class="flex items-center gap-2 text-[10px] font-mono text-zinc-600">
      <span>© {currentYear}</span>
      <span class="text-zinc-700">·</span>
      <span>Powered by</span>
      <a 
        href="https://astro.build" 
        target="_blank" 
        rel="noopener noreferrer"
        class="text-brand-purple/60 hover:text-brand-purple transition-colors cursor-pointer"
      >
        Astro
      </a>
    </div>

  </div>
</footer>
