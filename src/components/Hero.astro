---
const base = import.meta.env.BASE_URL;
---

<section id="inicio" class="relative min-h-[90vh] flex items-center overflow-hidden">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pt-28 pb-16 sm:pt-32 sm:pb-20">
    <div class="grid lg:grid-cols-5 gap-10 items-center">

      <!-- Left: Text content -->
      <div class="lg:col-span-3">

        <!-- Status badge -->
        <div class="opacity-0 animate-fade-up mb-6">
          <span class="inline-flex items-center gap-2.5 text-[11px] font-mono font-medium tracking-widest uppercase text-zinc-500 bg-brand-emerald/[0.06] border border-brand-emerald/20 rounded-full px-4 py-1.5">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-emerald opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-emerald"></span>
            </span>
            <span class="text-brand-emerald/90">Disponible para proyectos</span>
          </span>
        </div>

        <!-- Name -->
        <h1 class="opacity-0 animate-fade-up-delay-1 text-5xl sm:text-6xl lg:text-7xl font-black tracking-tight leading-[1.05]">
          <span class="text-white">Angel Ezequiel</span>
          <br />
          <span class="text-gradient">Barbosa Lomeli</span>
        </h1>

        <!-- Role -->
        <p class="opacity-0 animate-fade-up-delay-2 mt-6 text-lg sm:text-xl text-zinc-400 max-w-lg leading-relaxed">
          Ingeniero de Software especializado en
          <span class="text-brand-blue font-semibold"> backend</span>,
          <span class="text-brand-cyan font-semibold"> apps multiplataforma</span> y
          <span class="text-brand-purple font-semibold"> ciberseguridad</span>.
        </p>

        <!-- CTAs -->
        <div class="opacity-0 animate-fade-up-delay-3 mt-8 flex flex-wrap gap-4">
          <a href="#projects" class="btn-accent">
            <span>Ver Proyectos</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </a>
          <a href={`${base}/Angel_Ezequiel_Barbosa_Resume.pdf`.replace('//', '/')} download class="btn-primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            <span>Descargar CV</span>
          </a>
        </div>

        <!-- Tech stack pills -->
        <div class="opacity-0 animate-fade-up-delay-4 mt-10 flex flex-wrap items-center gap-2">
          <span class="text-[10px] font-mono text-zinc-600 uppercase tracking-widest mr-1">Stack —</span>
          {[
            { name: 'Java', color: 'text-brand-rose' },
            { name: 'Spring', color: 'text-brand-emerald' },
            { name: 'Flutter', color: 'text-brand-cyan' },
            { name: 'C#', color: 'text-brand-purple' },
            { name: 'Python', color: 'text-brand-amber' },
            { name: 'PostgreSQL', color: 'text-brand-blue' },
          ].map((tech) => (
            <span class={`tag ${tech.color}`}>{tech.name}</span>
          ))}
        </div>
      </div>

      <!-- Right: Pure CSS floating cards with JS parallax -->
      <div class="lg:col-span-2 hidden lg:flex justify-center">
        <div id="hero-cards" style="position:relative;height:420px;width:300px;flex-shrink:0;">

          <!-- Card 1 — Architecture (cyan) -->
          <div class="card-wrap" data-depth="14" style="position:absolute;top:0;left:0;">
            <div class="fc1 hcard" style="width:220px;background:rgba(255,255,255,0.028);border:1px solid rgba(255,255,255,0.09);border-radius:18px;padding:16px;box-shadow:0 4px 32px rgba(6,182,212,0.18);--hglow:rgba(6,182,212,0.5);">
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
                <div style="width:32px;height:32px;border-radius:10px;background:rgba(6,182,212,0.15);border:1px solid rgba(6,182,212,0.25);display:flex;align-items:center;justify-content:center;color:#06b6d4;flex-shrink:0;">
                  <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                </div>
                <span style="font-size:13px;font-weight:700;color:#fff;font-family:Inter,sans-serif;flex:1;">System.Architecture</span>
                <span style="position:relative;display:inline-flex;width:8px;height:8px;flex-shrink:0;">
                  <span style="position:absolute;inset:0;border-radius:50%;background:#10b981;opacity:0.75;animation:ping 1.5s cubic-bezier(0,0,0.2,1) infinite;"></span>
                  <span style="position:relative;display:block;width:100%;height:100%;border-radius:50%;background:#10b981;"></span>
                </span>
              </div>
              <div style="display:flex;flex-direction:column;gap:7px;">
                <div class="bar-fill" style="height:5px;border-radius:3px;background:rgba(6,182,212,0.28);width:80%;"></div>
                <div class="bar-fill" style="height:5px;border-radius:3px;background:rgba(59,130,246,0.20);width:100%;animation-delay:0.3s"></div>
                <div class="bar-fill" style="height:5px;border-radius:3px;background:rgba(255,255,255,0.06);width:55%;animation-delay:0.6s"></div>
              </div>
            </div>
          </div>

          <!-- Card 2 — Security (purple) -->
          <div class="card-wrap" data-depth="-10" style="position:absolute;top:120px;right:0;">
            <div class="fc2 hcard" style="width:190px;background:rgba(255,255,255,0.028);border:1px solid rgba(255,255,255,0.09);border-radius:18px;padding:16px;box-shadow:0 4px 32px rgba(139,92,246,0.18);--hglow:rgba(139,92,246,0.5);">
              <div style="display:flex;align-items:center;gap:12px;">
                <div style="width:44px;height:44px;border-radius:14px;flex-shrink:0;background:linear-gradient(135deg,rgba(139,92,246,0.18),rgba(244,63,94,0.08));border:1px solid rgba(139,92,246,0.25);display:flex;align-items:center;justify-content:center;color:#8b5cf6;">
                  <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
                <div>
                  <div style="font-size:14px;font-weight:700;color:#fff;font-family:Inter,sans-serif;">Security Auth</div>
                  <div style="font-size:11px;font-family:'JetBrains Mono',monospace;color:#10b981;margin-top:3px;">● Active</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Card 3 — Pipeline (green) -->
          <div class="card-wrap" data-depth="8" style="position:absolute;bottom:0;left:10px;">
            <div class="fc3 hcard" style="width:270px;background:rgba(255,255,255,0.028);border:1px solid rgba(255,255,255,0.09);border-radius:18px;padding:16px;box-shadow:0 4px 32px rgba(16,185,129,0.15);--hglow:rgba(16,185,129,0.5);">
              <div style="font-size:10px;font-family:'JetBrains Mono',monospace;color:rgba(16,185,129,0.7);letter-spacing:2px;text-transform:uppercase;margin-bottom:10px;">Data Pipeline</div>
              <div style="display:flex;flex-wrap:wrap;gap:6px;">
                {[
                  { label: 'Spring Boot', c: '#3b82f6' },
                  { label: 'Flutter',    c: '#06b6d4' },
                  { label: 'Py Scapy',   c: '#f43f5e' },
                  { label: 'PostgreSQL', c: '#f59e0b' },
                ].map(({ label, c }) => (
                  <span style={`padding:4px 10px;border-radius:6px;font-size:11px;font-family:'JetBrains Mono',monospace;font-weight:500;color:${c};background:${c}14;border:1px solid ${c}30;`}>{label}</span>
                ))}
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-0 animate-fade-up-delay-5">
    <div class="flex flex-col items-center gap-1.5">
      <span class="text-[9px] font-mono tracking-widest uppercase text-brand-purple/40">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-brand-purple/40 to-transparent"></div>
    </div>
  </div>
</section>

<div class="divider-gradient mx-auto max-w-5xl"></div>

<style>
  @keyframes ping {
    75%, 100% { transform: scale(2); opacity: 0; }
  }

  /* Card hover glow */
  .hcard {
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
    cursor: default;
  }
  .hcard:hover {
    box-shadow: 0 8px 48px var(--hglow, rgba(124,58,237,0.4)) !important;
    border-color: rgba(255,255,255,0.18) !important;
  }

  /* Card wrapper — receives JS parallax, smooth follow */
  .card-wrap {
    transition: transform 0.12s ease-out;
    will-change: transform;
  }

  /* Bar shimmer animation */
  @keyframes barLoad {
    from { opacity: 0.3; transform: scaleX(0.6); }
    to   { opacity: 1;   transform: scaleX(1); }
  }
  .bar-fill {
    transform-origin: left;
    animation: barLoad 1.8s ease-out forwards;
  }
</style>

<script is:inline>
  (function () {
    var container = document.getElementById('hero-cards');
    if (!container) return;

    var wraps = container.querySelectorAll('.card-wrap');
    var raf = null;
    var tx = 0, ty = 0; // target
    var cx = 0, cy = 0; // current (lerped)

    document.addEventListener('mousemove', function (e) {
      var rect = container.getBoundingClientRect();
      // normalize -0.5 to 0.5 relative to card container center
      tx = (e.clientX - rect.left - rect.width / 2) / rect.width;
      ty = (e.clientY - rect.top  - rect.height / 2) / rect.height;
    });

    function lerp(a, b, t) { return a + (b - a) * t; }

    function loop() {
      cx = lerp(cx, tx, 0.06);
      cy = lerp(cy, ty, 0.06);

      wraps.forEach(function (wrap) {
        var depth = parseFloat(wrap.getAttribute('data-depth') || '10');
        var ox = cx * depth;
        var oy = cy * depth * 0.6;
        wrap.style.transform = 'translate(' + ox.toFixed(2) + 'px,' + oy.toFixed(2) + 'px)';
      });

      raf = requestAnimationFrame(loop);
    }

    loop();
  })();
</script>
