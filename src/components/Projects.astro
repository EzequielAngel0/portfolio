---
// Projects — Compact with color
import projectData from '../data/proyectos.json';
const proyectos = projectData.proyectos;

const iconMap: Record<string, string> = {
  briefcase: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  database: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  code: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  server: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2',
  mobile: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z',
  cloud: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z',
  lock: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
};

const colorMap: Record<string, { text: string; bg: string; glow: string; ring: string }> = {
  cyan:    { text: 'text-brand-cyan',    bg: 'bg-brand-cyan/10',    glow: 'rgba(6, 182, 212, 0.3)',    ring: 'ring-brand-cyan/20' },
  blue:    { text: 'text-brand-blue',    bg: 'bg-brand-blue/10',    glow: 'rgba(59, 130, 246, 0.3)',   ring: 'ring-brand-blue/20' },
  purple:  { text: 'text-brand-purple',  bg: 'bg-brand-purple/10',  glow: 'rgba(139, 92, 246, 0.3)',   ring: 'ring-brand-purple/20' },
  emerald: { text: 'text-brand-emerald', bg: 'bg-brand-emerald/10', glow: 'rgba(16, 185, 129, 0.3)',   ring: 'ring-brand-emerald/20' },
  rose:    { text: 'text-brand-rose',    bg: 'bg-brand-rose/10',    glow: 'rgba(244, 63, 94, 0.3)',    ring: 'ring-brand-rose/20' },
  amber:   { text: 'text-brand-amber',   bg: 'bg-brand-amber/10',   glow: 'rgba(245, 158, 11, 0.3)',   ring: 'ring-brand-amber/20' },
};
---

<section id="projects" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 relative z-10">
  
  <div class="reveal mb-10">
    <span class="section-label">Proyectos</span>
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-white mb-3">
      Portafolio <span class="text-gradient">Técnico</span>
    </h2>
    <p class="text-zinc-400 max-w-2xl text-base sm:text-lg leading-relaxed">
      Desde apps de escritorio hasta ecosistemas móviles sincronizados.
    </p>
  </div>

  <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
    {proyectos.map((p, i) => {
      const colors = colorMap[p.color] || colorMap.cyan;
      const iconPath = iconMap[p.icon] || iconMap.briefcase;
      return (
        <div 
          class="reveal card flex flex-col p-5 group cursor-default"
          data-delay={`${i * 0.1}`}
          style={`--card-glow: ${colors.glow}`}
        >
          <div class="flex items-center gap-2.5 mb-4 relative z-10">
            <div class={`h-8 w-8 rounded-lg bg-gradient-to-br ${colors.bg} flex items-center justify-center ${colors.text} ring-1 ${colors.ring}`}>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconPath} />
              </svg>
            </div>
            <span class={`text-[10px] font-mono font-semibold tracking-widest uppercase ${colors.text} opacity-70`}>{p.subtitle}</span>
          </div>

          <div class="flex-grow relative z-10">
            <h3 class="text-lg font-bold text-white mb-2 group-hover:text-zinc-100 transition-colors">{p.title}</h3>
            <p class="text-zinc-500 text-sm leading-relaxed mb-4">{p.description}</p>
          </div>

          <div class="pt-3 border-t border-white/[0.04] mt-auto flex flex-col gap-3 relative z-10">
            <div class="flex flex-wrap gap-1">
              {p.tags.map((t: string) => (
                <span class="tag text-[9px]">{t}</span>
              ))}
            </div>
            <a href={p.repo} target="_blank" rel="noopener noreferrer"
              class={`inline-flex items-center gap-1.5 text-[11px] font-semibold text-zinc-500 hover:text-zinc-200 transition-colors cursor-pointer group/link`}>
              Ver código
              <svg class="h-3 w-3 group-hover/link:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </a>
          </div>
        </div>
      );
    })}
  </div>
</section>

<div class="divider-gradient mx-auto max-w-5xl"></div>
