---
// Diagrama de arquitectura de ACP Suite (doc 04): SVG artesanal derivado del
// Mermaid del case study. La geometria es UNA sola (mismos trazos) y las
// etiquetas cambian por locale; los colores salen de los tokens del tema via
// CSS, asi que hereda claro/oscuro sin JS. Nombra piezas, nunca hosts, IPs ni
// versiones (doc 02, regla 3). El texto es <text> real: seleccionable y
// accesible, con role="img" + <title>/<desc>.
import type { Locale } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

type NodeId =
  | 'users'
  | 'cloudflare'
  | 'cloudflared'
  | 'lb'
  | 'gateway'
  | 'apiPublic'
  | 'apiInternal'
  | 'static'
  | 'pgbouncer'
  | 'postgres'
  | 'replica'
  | 'field';

interface NodeBox {
  x: number;
  y: number;
  w: number;
  h: number;
  shape: 'rect' | 'cylinder';
}

// Coordenadas unicas para ambos idiomas.
const nodes: Record<NodeId, NodeBox> = {
  users: { x: 235, y: 16, w: 250, h: 44, shape: 'rect' },
  cloudflare: { x: 220, y: 112, w: 280, h: 58, shape: 'rect' },
  cloudflared: { x: 260, y: 234, w: 200, h: 44, shape: 'rect' },
  lb: { x: 220, y: 330, w: 280, h: 44, shape: 'rect' },
  gateway: { x: 210, y: 426, w: 300, h: 44, shape: 'rect' },
  apiPublic: { x: 16, y: 530, w: 214, h: 58, shape: 'rect' },
  apiInternal: { x: 253, y: 530, w: 214, h: 58, shape: 'rect' },
  static: { x: 490, y: 530, w: 214, h: 58, shape: 'rect' },
  pgbouncer: { x: 162, y: 650, w: 160, h: 44, shape: 'rect' },
  postgres: { x: 137, y: 746, w: 210, h: 72, shape: 'cylinder' },
  replica: { x: 485, y: 746, w: 150, h: 72, shape: 'cylinder' },
  field: { x: 8, y: 322, w: 212, h: 72, shape: 'rect' },
};

// Flechas (elbows estilo flowchart); la replica va discontinua.
const edges: { d: string; dashed?: boolean }[] = [
  { d: 'M360 60 V112' },
  { d: 'M360 170 V234' },
  { d: 'M360 278 V330' },
  { d: 'M360 374 V426' },
  { d: 'M360 470 V500 H123 V530' },
  { d: 'M360 470 V530' },
  { d: 'M360 470 V500 H597 V530' },
  { d: 'M123 588 V619 H242 V650' },
  { d: 'M360 588 V619 H242 V650' },
  { d: 'M242 694 V746' },
  { d: 'M347 790 H485', dashed: true },
  { d: 'M113 394 V448 H210' },
];

interface NodeLabel {
  title: string;
  sub?: string;
}

interface EdgeLabel {
  x: number;
  y: number;
  anchor: 'start' | 'middle';
  lines: [string, string];
}

// Etiquetas por idioma, tomadas del Mermaid del fuente (sin acentos: van en
// mono, misma convencion que las tiras de estado del sitio).
const labels: Record<Locale, Record<NodeId, NodeLabel>> = {
  es: {
    users: { title: 'Usuarios web y apps' },
    cloudflare: { title: 'Cloudflare', sub: 'DNS · TLS · cache de estaticos' },
    cloudflared: { title: 'cloudflared' },
    lb: { title: 'Load balancer privado OCI' },
    gateway: { title: 'Gateway nginx en 2 VMs de app' },
    apiPublic: { title: 'API publica en Go', sub: 'solo lectura' },
    apiInternal: { title: 'API interna en Go', sub: 'JWT + RBAC' },
    static: { title: 'Estaticos', sub: 'www Next.js · admin React' },
    pgbouncer: { title: 'PgBouncer' },
    postgres: { title: 'PostgreSQL primario' },
    replica: { title: 'Replica' },
    field: { title: 'Apps de campo offline-first', sub: 'taquilla · chofer · paqueteria' },
  },
  en: {
    users: { title: 'Web users and apps' },
    cloudflare: { title: 'Cloudflare', sub: 'DNS · TLS · static cache' },
    cloudflared: { title: 'cloudflared' },
    lb: { title: 'Private OCI load balancer' },
    gateway: { title: 'nginx gateway on 2 app VMs' },
    apiPublic: { title: 'Public Go API', sub: 'read only' },
    apiInternal: { title: 'Internal Go API', sub: 'JWT + RBAC' },
    static: { title: 'Static', sub: 'Next.js www · React admin' },
    pgbouncer: { title: 'PgBouncer' },
    postgres: { title: 'PostgreSQL primary' },
    replica: { title: 'Replica' },
    field: { title: 'Offline-first field apps', sub: 'POS · driver · parcels' },
  },
};

const edgeLabels: Record<Locale, EdgeLabel[]> = {
  es: [
    { x: 372, y: 196, anchor: 'start', lines: ['tunel saliente,', 'sin puertos de entrada'] },
    { x: 125, y: 408, anchor: 'start', lines: ['cola cifrada,', 'sincronizacion'] },
    { x: 416, y: 760, anchor: 'middle', lines: ['replicacion', 'streaming'] },
  ],
  en: [
    { x: 372, y: 196, anchor: 'start', lines: ['outbound tunnel,', 'no inbound ports'] },
    { x: 125, y: 408, anchor: 'start', lines: ['encrypted queue,', 'sync'] },
    { x: 416, y: 760, anchor: 'middle', lines: ['streaming', 'replication'] },
  ],
};

const a11y: Record<Locale, { title: string; desc: string }> = {
  es: {
    title: 'Diagrama de arquitectura de la plataforma de ACP',
    desc: 'El tráfico de usuarios entra por Cloudflare y un túnel saliente de cloudflared (sin puertos de entrada) hacia un load balancer privado de OCI y un gateway nginx en dos VMs de aplicación. El gateway sirve la API pública en Go de solo lectura, la API interna en Go con JWT y RBAC, y los estáticos de Next.js y React. Ambas APIs consultan una PostgreSQL primaria a través de PgBouncer, con réplica por replicación streaming. Las apps de campo offline-first (taquilla, chofer y paquetería) sincronizan con el gateway mediante una cola cifrada.',
  },
  en: {
    title: 'ACP platform architecture diagram',
    desc: 'User traffic enters through Cloudflare and an outbound cloudflared tunnel (no inbound ports) to a private OCI load balancer and an nginx gateway on two app VMs. The gateway serves the read-only public Go API, the internal Go API with JWT and RBAC, and the Next.js and React static assets. Both APIs reach a primary PostgreSQL through PgBouncer, with a streaming replica. The offline-first field apps (POS, driver, and parcels) sync with the gateway through an encrypted queue.',
  },
};

const nodeEntries = Object.entries(nodes) as [NodeId, NodeBox][];
const cylinderBody = ({ x, y, w, h }: NodeBox) =>
  `M${x} ${y + 10} v${h - 20} a${w / 2} 10 0 0 0 ${w} 0 v${-(h - 20)}`;
---

<figure class="diagram">
  <div class="diagram-scroll" tabindex="0" role="group" aria-label={a11y[locale].title}>
    <svg
      viewBox="0 0 720 850"
      role="img"
      aria-labelledby="acp-diagram-title acp-diagram-desc"
      class="diagram-svg"
    >
      <title id="acp-diagram-title">{a11y[locale].title}</title>
      <desc id="acp-diagram-desc">{a11y[locale].desc}</desc>

      <defs>
        <marker
          id="acp-arrow"
          viewBox="0 0 10 10"
          refX="8"
          refY="5"
          markerWidth="7"
          markerHeight="7"
          orient="auto-start-reverse"
        >
          <path d="M0 0 L10 5 L0 10 z" class="arrow-head"></path>
        </marker>
      </defs>

      {
        edges.map((edge) => (
          <path
            d={edge.d}
            class:list={['edge', edge.dashed && 'edge-dashed']}
            marker-end="url(#acp-arrow)"
          />
        ))
      }

      {
        edgeLabels[locale].map((label) => (
          <text x={label.x} y={label.y} text-anchor={label.anchor} class="edge-label">
            <tspan x={label.x} dy="0">
              {label.lines[0]}
            </tspan>
            <tspan x={label.x} dy="14">
              {label.lines[1]}
            </tspan>
          </text>
        ))
      }

      {
        nodeEntries.map(([id, node]) => {
          const label = labels[locale][id];
          const cx = node.x + node.w / 2;
          return (
            <g>
              {node.shape === 'rect' ? (
                <rect
                  x={node.x}
                  y={node.y}
                  width={node.w}
                  height={node.h}
                  rx="4"
                  class="node-box"
                />
              ) : (
                <>
                  <path d={cylinderBody(node)} class="node-box" />
                  <ellipse cx={cx} cy={node.y + 10} rx={node.w / 2} ry="10" class="node-box" />
                </>
              )}
              {node.shape === 'cylinder' ? (
                <text x={cx} y={node.y + node.h / 2 + 12} text-anchor="middle" class="node-title">
                  {label.title}
                </text>
              ) : label.sub ? (
                <>
                  <text x={cx} y={node.y + node.h / 2 - 5} text-anchor="middle" class="node-title">
                    {label.title}
                  </text>
                  <text x={cx} y={node.y + node.h / 2 + 14} text-anchor="middle" class="node-sub">
                    {label.sub}
                  </text>
                </>
              ) : (
                <text x={cx} y={node.y + node.h / 2 + 4} text-anchor="middle" class="node-title">
                  {label.title}
                </text>
              )}
            </g>
          );
        })
      }
    </svg>
  </div>
</figure>

<style>
  .diagram {
    margin: 0;
  }

  /* En pantallas angostas el diagrama scrollea en su propio contenedor en vez
     de encoger el texto a lo ilegible; tabindex lo hace operable por teclado. */
  .diagram-scroll {
    overflow-x: auto;
    border-radius: var(--radius-md);
    background-color: var(--color-surface);
    box-shadow: var(--card-shadow);
  }

  .diagram-svg {
    display: block;
    width: 100%;
    min-width: 40rem;
    height: auto;
    padding: 0.75rem;
  }

  /* Trazos derivados del token de tinta: se adaptan a ambos temas */
  .node-box {
    fill: var(--color-paper);
    stroke: color-mix(in srgb, var(--color-ink) 32%, transparent);
    stroke-width: 1;
  }

  .edge {
    fill: none;
    stroke: color-mix(in srgb, var(--color-ink) 45%, transparent);
    stroke-width: 1.25;
  }

  .edge-dashed {
    stroke-dasharray: 5 4;
  }

  .arrow-head {
    fill: color-mix(in srgb, var(--color-ink) 45%, transparent);
  }

  .node-title {
    fill: var(--color-ink);
    font-family: var(--font-mono);
    font-size: 12.5px;
    font-weight: 500;
  }

  .node-sub,
  .edge-label {
    fill: var(--color-ink-soft);
    font-family: var(--font-mono);
    font-size: 10.5px;
  }
</style>
