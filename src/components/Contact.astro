---
// Contact section V4 - Colorful Bento
---

<section id="contact" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 relative z-10">
  
  <div class="mb-16">
    <h2 class="text-4xl sm:text-5xl font-black tracking-tight text-white mb-4">
      Conectemos <span class="text-brand-emerald">Ideas</span>
    </h2>
    <p class="text-zinc-400 mt-4 max-w-2xl text-lg font-medium">
      Soluciones reales creadas colaborativamente.
    </p>
  </div>

  <div class="grid lg:grid-cols-2 gap-8 items-start">
    
    <!-- Redes & Canales (Bento blocks) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 h-full">
      
      <!-- Linkedin Block -->
      <a href="https://linkedin.com/in/angelezequiel" target="_blank" rel="noopener noreferrer" class="bento-card bento-card-hover p-8 flex flex-col justify-center items-center text-center group" style="--hover-color: rgba(10, 102, 194, 0.4)">
        <div class="absolute inset-0 bg-[#0A66C2]/10 blur-[40px] opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
        <div class="h-16 w-16 mb-4 rounded-2xl bg-gradient-to-br from-[#0A66C2] to-[#0A66C2]/70 shadow-lg flex items-center justify-center text-white relative z-10 group-hover:scale-110 transition-transform">
           <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        </div>
        <h4 class="text-xl font-bold text-white mb-1 relative z-10">LinkedIn</h4>
        <p class="text-xs text-zinc-400 font-mono relative z-10">/angelezequiel</p>
      </a>

      <!-- GitHub Block -->
      <a href="https://github.com/EzequielAngel0" target="_blank" rel="noopener noreferrer" class="bento-card bento-card-hover p-8 flex flex-col justify-center items-center text-center group" style="--hover-color: rgba(255, 255, 255, 0.2)">
        <div class="absolute inset-0 bg-white/5 blur-[40px] opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
        <div class="h-16 w-16 mb-4 rounded-2xl bg-gradient-to-br from-zinc-700 to-zinc-900 shadow-lg flex items-center justify-center text-white relative z-10 group-hover:scale-110 transition-transform border border-white/10">
           <svg class="h-8 w-8 text-current" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </div>
        <h4 class="text-xl font-bold text-white mb-1 relative z-10">GitHub</h4>
        <p class="text-xs text-zinc-400 font-mono relative z-10">@EzequielAngel0</p>
      </a>

      <!-- Quick Contacts Block (Span 2) -->
      <div class="sm:col-span-2 grid grid-cols-2 gap-6">
        <a href="mailto:barbosalomeliangelezequiel@gmail.com" class="bento-card bento-card-hover flex flex-col items-center justify-center py-6 px-4 gap-3 text-center group" style="--hover-color: rgba(244, 63, 94, 0.4)">
          <div class="p-3 bg-brand-rose/10 text-brand-rose rounded-xl group-hover:scale-110 group-hover:bg-brand-rose group-hover:text-white transition-all shadow-lg">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <span class="font-bold text-sm text-zinc-300">Correo</span>
        </a>
        <a href="https://wa.me/523320191633" target="_blank" rel="noopener noreferrer" class="bento-card bento-card-hover flex flex-col items-center justify-center py-6 px-4 gap-3 text-center group" style="--hover-color: rgba(16, 185, 129, 0.4)">
          <div class="p-3 bg-brand-emerald/10 text-brand-emerald rounded-xl group-hover:scale-110 group-hover:bg-brand-emerald group-hover:text-white transition-all shadow-lg">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          </div>
          <span class="font-bold text-sm text-zinc-300">WhatsApp</span>
        </a>
      </div>
    </div>

    <!-- Contact Form (Bento block) -->
    <div class="bento-card flex flex-col p-8 sm:p-10 relative overflow-hidden h-full">
      <div class="absolute -top-40 -right-40 w-96 h-96 bg-brand-cyan/20 rounded-full blur-[100px] pointer-events-none mix-blend-screen"></div>
      
      <h3 class="text-3xl font-black text-white mb-2 relative z-10">Enviar Propuesta</h3>
      <p class="text-zinc-400 mb-8 font-medium relative z-10">Transmisión encriptada directo a mi inbox.</p>

      <form action="#" class="space-y-6 relative z-10 flex-col flex flex-grow">
        <div>
          <label for="email" class="block text-xs font-bold text-zinc-400 mb-2 uppercase tracking-wider">Tu Email</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="ceo@empresa.com"
            class="block w-full rounded-xl border border-white/10 bg-black/40 px-4 py-3.5 text-sm text-zinc-100 placeholder:text-zinc-600 focus:border-brand-emerald focus:bg-black/60 focus:ring-1 focus:ring-brand-emerald transition-all outline-none shadow-inner"
          />
        </div>

        <div class="flex-grow">
           <label for="message" class="block text-xs font-bold text-zinc-400 mb-2 uppercase tracking-wider">Construyamos Algo</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            placeholder="Especifica el objetivo técnico o la propuesta arquitectónica."
            class="block w-full h-full min-h-[120px] rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-sm text-zinc-100 placeholder:text-zinc-600 focus:border-brand-emerald focus:bg-black/60 focus:ring-1 focus:ring-brand-emerald transition-all outline-none resize-none shadow-inner"
          ></textarea>
        </div>

        <button
          type="submit"
          class="inline-flex w-full items-center justify-center gap-3 rounded-xl bg-gradient-to-r from-brand-emerald to-brand-cyan px-8 py-4 font-bold text-white transition-transform hover:scale-[1.02] shadow-[0_10px_30px_rgba(16,185,129,0.3)] mt-4"
        >
          Transmitir Mensaje
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </button>
      </form>
    </div>

  </div>
</section>
