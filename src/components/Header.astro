---
interface Props {
  currentPage?: 'home' | 'certificados';
}

const { currentPage = 'home' } = Astro.props;
// Force absolute paths based on root base URL for correct navigation
const base = import.meta.env.BASE_URL;

const navLinks = [
  { label: 'Inicio', href: currentPage === 'home' ? '#inicio' : `${base}` },
  { label: 'Sobre mí', href: currentPage === 'home' ? '#about' : `${base}#about` },
  { label: 'Proyectos', href: currentPage === 'home' ? '#projects' : `${base}#projects` },
  { label: 'Habilidades', href: currentPage === 'home' ? '#skills' : `${base}#skills` },
  { label: 'Certificados', href: `${base}/certificados`.replace('//', '/') }, // Fixed missing slash
  { label: 'Contacto', href: currentPage === 'home' ? '#contact' : `${base}#contact` },
];
---

<header
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300 backdrop-blur-3xl bg-surface-50/50 border-b border-white/5"
  id="main-header"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href={base} class="flex items-center gap-3 group outline-none">
        <span class="font-bold text-sm text-zinc-200 tracking-tight group-hover:text-white transition-colors hidden sm:block">
          Angel <span class="text-brand-cyan">Ezequiel</span>
        </span>
      </a>

      <!-- Links desktop -->
      <ul class="hidden md:flex items-center gap-1 bg-white/5 p-1 rounded-full border border-white/5">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="hover:bg-white/10 hover:text-white text-zinc-300 transition-colors px-4 py-1.5 rounded-full text-sm font-medium outline-none"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="hidden md:flex items-center">
        <!-- Fixed CV Download Link - Uses Root Context -->
        <a
          href="/portfolio/BarbosaLomeliAngelEzequiel-CV.pdf"
          class="btn-glass flex items-center gap-2 px-5 py-2 text-sm font-semibold shadow-[0_0_15px_rgba(6,182,212,0.15)] group"
          download
        >
          <svg class="w-4 h-4 text-brand-cyan group-hover:animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          <span class="relative z-10">Currículum</span>
        </a>
      </div>

      <!-- Botón menú móvil -->
      <button
        id="mobileMenuButton"
        class="md:hidden flex items-center justify-center h-10 w-10 rounded-xl bg-white/5 border border-white/10 text-zinc-300 hover:text-white hover:bg-white/10 transition-colors"
        aria-label="Abrir menú"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </nav>
  </div>

  <!-- Menú móvil -->
  <div
    id="mobileMenu"
    class="md:hidden absolute top-full left-0 right-0 bg-surface-50/95 backdrop-blur-2xl border-b border-white/5 px-4 pb-6 pt-2 space-y-2 hidden transform origin-top transition-all"
  >
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class="block px-4 py-3 rounded-xl text-sm font-medium text-zinc-300 hover:text-white hover:bg-white/10 transition-colors"
        >
          {link.label}
        </a>
      ))
    }
    <div class="pt-4 mt-2 border-t border-white/5">
      <a
        href="/portfolio/BarbosaLomeliAngelEzequiel-CV.pdf"
        class="flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-brand-blue to-brand-cyan px-4 py-3 text-sm font-bold text-white shadow-lg shadow-brand-cyan/20"
        download
      >
        <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
        Descargar CV
      </a>
    </div>
  </div>
</header>
