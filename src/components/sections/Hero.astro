---
// Hero (doc 05): linea de estado [.] con punto verde (pulso CSS, unico loop
// permitido), titular grande en Archivo, subtitulo mono y CTAs. El contenido
// nace visible; GSAP solo escalona la entrada desde [data-boot].
import type { Locale } from '../../i18n/ui';
import { useTranslations, localizePath, cvPath } from '../../i18n/utils';
import Button from '../ui/Button.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="pt-16 pb-section sm:pt-24">
  <p data-boot class="font-mono text-label font-medium tracking-wide text-accent uppercase">
    <span aria-hidden="true" class="inline-flex items-center"
      >[<span class="status-pulse mx-1 inline-block size-2 rounded-full bg-accent"></span>]</span
    >
    {t('hero.status')}
  </p>

  <h1 data-boot class="mt-5 max-w-3xl text-display">{t('hero.title')}</h1>

  <p data-boot class="mt-5 font-mono text-ink-soft">{t('hero.subtitle')}</p>

  <div data-boot class="mt-9 flex flex-wrap items-center gap-3">
    <Button href={localizePath('acp-suite', locale)}>{t('hero.ctaCase')}</Button>
    <Button href={cvPath(locale)} variant="secondary" download>
      {t('hero.ctaCv')}
    </Button>
  </div>
</section>
