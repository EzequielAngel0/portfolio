---
// Proyectos (docs 02 y 04): tarjetas tipograficas (captura opcional, D8),
// badge de estado real y links a demo en vivo (si existe) y repo. La reja
// admite futuros proyectos; featured va primero. ACP no entra aqui: es el
// case study.
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import { getLocalized } from '../../lib/content';
import Section from '../ui/Section.astro';
import Badge from '../ui/Badge.astro';
import Tag from '../ui/Tag.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const projects = (await getLocalized('projects', locale)).sort(
  (a, b) => Number(b.data.featured) - Number(a.data.featured),
);
---

<Section id="proyectos" label={t('projects.title')}>
  <ul data-stagger class="grid gap-5 md:grid-cols-2">
    {
      projects.map((project) => (
        <li>
          <article class="flex h-full flex-col rounded-md bg-surface p-6 shadow-card">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <h3 class="text-xl font-semibold">{project.data.title}</h3>
              <Badge status={project.data.status} locale={locale} />
            </div>

            <p class="mt-3 text-ink-soft">{project.data.summary}</p>
            <p class="mt-3 font-mono text-label text-ink-soft">{project.data.dates}</p>

            <ul class="mt-4 flex flex-wrap gap-2">
              {project.data.stack.map((item) => (
                <li>
                  <Tag>{item}</Tag>
                </li>
              ))}
            </ul>

            {(project.data.demoUrl || project.data.repoUrl) && (
              <div class="mt-auto flex flex-wrap gap-x-6 pt-5">
                {project.data.demoUrl && (
                  <a
                    href={project.data.demoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group inline-flex min-h-10 items-center gap-2 font-mono text-label font-medium text-accent hover:underline"
                  >
                    {t('projects.viewDemo')}
                    <span class="sr-only">({t('a11y.newTab')})</span>
                    <Icon
                      name="external"
                      size={14}
                      class="transition-transform duration-150 ease-out group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
                    />
                  </a>
                )}
                {project.data.repoUrl && (
                  <a
                    href={project.data.repoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group inline-flex min-h-10 items-center gap-2 font-mono text-label font-medium text-accent hover:underline"
                  >
                    {t('projects.viewRepo')}
                    <span class="sr-only">({t('a11y.newTab')})</span>
                    <Icon
                      name="external"
                      size={14}
                      class="transition-transform duration-150 ease-out group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
                    />
                  </a>
                )}
              </div>
            )}
          </article>
        </li>
      ))
    }
  </ul>
</Section>
