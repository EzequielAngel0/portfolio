---
// Proyectos (docs 02 y 04): tarjetas tipograficas (captura opcional, D8),
// badge de estado real y link al repo. La reja admite futuros proyectos;
// featured va primero. ACP no entra aqui: es el case study.
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import { getLocalized } from '../../lib/content';
import Section from '../ui/Section.astro';
import Badge from '../ui/Badge.astro';
import Tag from '../ui/Tag.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const projects = (await getLocalized('projects', locale)).sort(
  (a, b) => Number(b.data.featured) - Number(a.data.featured),
);
---

<Section label={t('projects.title')}>
  <ul class="grid gap-5 md:grid-cols-2">
    {
      projects.map((project) => (
        <li>
          <article class="flex h-full flex-col rounded-md border border-line bg-surface p-6">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <h3 class="text-xl font-semibold">{project.data.title}</h3>
              <Badge status={project.data.status} locale={locale} />
            </div>

            <p class="mt-3 text-ink-soft">{project.data.summary}</p>
            <p class="mt-3 font-mono text-label text-ink-soft">{project.data.dates}</p>

            <ul class="mt-4 flex flex-wrap gap-2">
              {project.data.stack.map((item) => (
                <li>
                  <Tag>{item}</Tag>
                </li>
              ))}
            </ul>

            {project.data.repoUrl && (
              <a
                href={project.data.repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="group mt-auto inline-flex min-h-10 items-center gap-2 self-start pt-5 font-mono text-label font-medium text-accent hover:underline"
              >
                {t('projects.viewRepo')}
                <Icon
                  name="external"
                  size={14}
                  class="transition-transform duration-150 group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
                />
              </a>
            )}
          </article>
        </li>
      ))
    }
  </ul>
</Section>
