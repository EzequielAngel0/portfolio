---
// Certificaciones en el home (docs 01 y 02, T3): solo las destacadas con
// home: true (OCI, Google Cybersecurity, ONE Tech Advanced) y un enlace al
// catalogo completo en /certificaciones/ (par EN: /en/certifications/).
import certifications from '../../data/certifications.json';
import type { Locale } from '../../i18n/ui';
import { useTranslations, certsPath } from '../../i18n/utils';
import Section from '../ui/Section.astro';
import CertCard from '../ui/CertCard.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const homeCerts = certifications.featured.filter((cert) => cert.home);
---

<Section label={t('certifications.title')}>
  <ul data-stagger class="grid gap-5 md:grid-cols-3">
    {
      homeCerts.map((cert) => (
        <li>
          <CertCard
            name={cert.name}
            issuer={cert.issuer}
            year={cert.year}
            url={cert.url}
            locale={locale}
          />
        </li>
      ))
    }
  </ul>

  <a
    href={certsPath(locale)}
    class="group mt-8 inline-flex min-h-10 items-center gap-2 font-mono text-label font-medium text-accent hover:underline"
  >
    {t('certifications.viewAll')}
    <Icon
      name="arrow-right"
      size={16}
      class="transition-transform duration-150 ease-out group-hover:translate-x-0.5"
    />
  </a>
</Section>
