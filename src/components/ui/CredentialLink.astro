---
// Link a la credencial verificable (doc 02): externo, con affordance clara de
// pestana nueva. El objetivo del sitio es "verificable con un clic".
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import Icon from './Icon.astro';

interface Props {
  href: string;
  locale: Locale;
}

const { href, locale } = Astro.props;
const t = useTranslations(locale);
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="group inline-flex min-h-10 items-center gap-1.5 font-mono text-label font-medium text-accent hover:underline"
>
  {t('certifications.view')}
  <span class="sr-only">({t('a11y.newTab')})</span>
  <Icon
    name="external"
    size={14}
    class="transition-transform duration-150 ease-out group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
  />
</a>
