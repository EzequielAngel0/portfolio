---
// Carrusel de capturas (docs 05 y 06). Solo se monta cuando hay capturas (D8):
// la pagina lo renderiza condicionalmente, asi Draggable no entra al bundle
// mientras no exista. Mejora progresiva: la base es una tira con scroll-snap
// nativo (usable sin JS); el JS habilita los controles, anuncia el estado y
// agrega arrastre con GSAP Draggable (via proxy, sin tocar el DOM de la lista).
// Reduced motion: sin arrastre ni tweens, queda el scroll nativo instantaneo.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import Icon from './Icon.astro';

interface Props {
  items: { src: ImageMetadata; alt: string }[];
  locale: Locale;
}

const { items, locale } = Astro.props;
const t = useTranslations(locale);

const statusTemplate = t('carousel.status');
const statusFor = (index: number) =>
  statusTemplate.replace('{current}', String(index + 1)).replace('{total}', String(items.length));
---

<div
  class="carousel"
  data-carousel
  data-status-template={statusTemplate}
  role="group"
  aria-roledescription="carousel"
  aria-label={t('screenshots.title')}
>
  <div class="mb-3 flex items-center gap-2" data-carousel-controls hidden>
    <button
      type="button"
      data-carousel-prev
      aria-label={t('carousel.prev')}
      aria-disabled="true"
      class="grid size-10 place-items-center rounded-sm border border-line text-ink transition-[transform,border-color] duration-150 ease-out hover:border-ink/35 active:scale-[0.96] aria-disabled:opacity-40"
    >
      <Icon name="arrow-left" size={18} />
    </button>
    <button
      type="button"
      data-carousel-next
      aria-label={t('carousel.next')}
      aria-disabled={items.length < 2 ? 'true' : 'false'}
      class="grid size-10 place-items-center rounded-sm border border-line text-ink transition-[transform,border-color] duration-150 ease-out hover:border-ink/35 active:scale-[0.96] aria-disabled:opacity-40"
    >
      <Icon name="arrow-right" size={18} />
    </button>
    <p class="ml-2 font-mono text-label text-ink-soft" data-carousel-status aria-live="polite">
      {statusFor(0)}
    </p>
  </div>

  <ul class="carousel-track" data-carousel-track tabindex="0" aria-label={t('screenshots.title')}>
    {
      items.map((item, index) => (
        <li
          class="carousel-slide"
          role="group"
          aria-roledescription="slide"
          aria-label={statusFor(index)}
        >
          <Image
            src={item.src}
            alt={item.alt}
            widths={[480, 800, 1200]}
            sizes="(min-width: 64rem) 38rem, 85vw"
            loading="lazy"
            class="slide-image"
          />
        </li>
      ))
    }
  </ul>
</div>

<style>
  .carousel-track {
    /* Posicionado para que offsetLeft de los slides se mida contra el track
       (sin esto se mide contra body y el snap apunta a coordenadas de pagina) */
    position: relative;
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;
    padding-bottom: 0.5rem;
  }

  /* Mientras GSAP arrastra o hace el tween de snap, el snap nativo se apaga
     para no pelear con el tween; se restituye al terminar. */
  .carousel-track.is-dragging {
    scroll-snap-type: none;
  }

  .carousel[data-enhanced] .carousel-track {
    cursor: grab;
  }

  .carousel[data-enhanced] .carousel-track:active {
    cursor: grabbing;
  }

  .carousel-slide {
    flex: none;
    width: min(85%, 38rem);
    scroll-snap-align: center;
    /* Marco limpio (doc 05): sombra en capas y radios concentricos,
       exterior (10) = interior (4) + padding (6). */
    border-radius: var(--radius-md);
    background-color: var(--color-surface);
    padding: 0.375rem;
    box-shadow: var(--card-shadow);
  }

  /* Altura fija del marco: capturas de escritorio y movil conviven sin CLS */
  .slide-image {
    display: block;
    width: 100%;
    height: clamp(16rem, 50vh, 28rem);
    object-fit: contain;
    border-radius: var(--radius-xs);
    /* Outline de imagen (doc 05): negro/blanco puros a baja opacidad */
    outline: 1px solid rgb(0 0 0 / 0.1);
    outline-offset: -1px;
  }

  :global([data-theme='dark']) .slide-image {
    outline-color: rgb(255 255 255 / 0.1);
  }
</style>

<script>
  // Logica compartida con el carrusel de certificaciones (T3).
  import '../../scripts/carousel';
</script>
