---

<section id="skills" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 relative z-10">
  
  <div class="mb-16">
    <h2 class="text-4xl sm:text-5xl font-black tracking-tight text-white mb-4">
      Ecosistema <span class="text-brand-purple">Tecnológico</span>
    </h2>
    <p class="text-zinc-400 mt-4 max-w-2xl text-lg font-medium">
      Soluciones reales creadas con el stack correcto.
    </p>
  </div>

  <div class="grid gap-6 grid-cols-1 md:grid-cols-3">
    {categories.map((cat) => (
      <div 
        class={`bento-card bento-card-hover p-6 sm:p-8 flex flex-col justify-between group ${cat.colSpan} border-white/5 relative`}
        style={`--hover-color: ${cat.color}`}
      >
        <!-- Background inner glow -->
        <div class={`absolute inset-0 ${cat.bgClass.split(' ')[0]} blur-[80px] opacity-0 group-hover:opacity-[0.15] transition-opacity duration-500 rounded-[24px] pointer-events-none`}></div>
        
        <div class="flex items-start gap-4 mb-8 relative z-10">
          <div class={`p-3 rounded-2xl ${cat.bgClass} shadow-inner`}>
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={cat.icon} />
            </svg>
          </div>
          <div class="pt-1">
            <h3 class="text-xl sm:text-2xl font-bold text-white tracking-tight">{cat.title}</h3>
            <p class="text-[11px] font-mono tracking-wider uppercase text-zinc-500 mt-1">{cat.desc}</p>
          </div>
        </div>

        <div class="mt-auto relative z-10">
          <div class="flex flex-wrap gap-2">
            {cat.skills.map((skill) => (
              <span class="tag-v4 hover:text-white transition-colors">
                {skill}
              </span>
            ))}
          </div>
        </div>

      </div>
    ))}
  </div>
</section>
