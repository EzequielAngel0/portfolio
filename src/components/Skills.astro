<section id="skills" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 relative z-10">
  
  <div class="reveal mb-10">
    <span class="section-label">Habilidades</span>
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-white mb-3">
      Ecosistema <span class="text-gradient">Tecnológico</span>
    </h2>
    <p class="text-zinc-400 max-w-2xl text-base sm:text-lg leading-relaxed">
      Soluciones reales creadas con el stack correcto.
    </p>
  </div>

  <div class="grid gap-3 grid-cols-1 md:grid-cols-3">
    {categories.map((cat, i) => (
      <div 
        class={`reveal card p-5 flex flex-col justify-between group cursor-default ${cat.span}`}
        data-delay={`${i * 0.08}`}
        style={`--card-glow: ${cat.glow}`}
      >
        <div class="flex items-start gap-2.5 mb-5 relative z-10">
          <div class={`p-2 rounded-lg bg-gradient-to-br ${cat.bg} flex items-center justify-center ${cat.color} ring-1 ${cat.ring} group-hover:scale-110 transition-transform`}>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={cat.icon} />
            </svg>
          </div>
          <div class="pt-0.5">
            <h3 class="text-base font-bold text-white tracking-tight">{cat.title}</h3>
            <p class={`text-[11px] font-mono tracking-wide ${cat.color} opacity-60 mt-0.5`}>{cat.desc}</p>
          </div>
        </div>

        <div class="mt-auto relative z-10">
          <div class="flex flex-wrap gap-1.5">
            {cat.skills.map((skill) => (
              <span class={`tag hover:${cat.color} hover:border-current/20 transition-all`}>{skill}</span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<div class="divider-gradient mx-auto max-w-5xl"></div>
