---
// Certificate Preview — Compact with color
import certData from '../data/certificados.json';
const certCount = certData.certificados.length;
const base = import.meta.env.BASE_URL;
---

<section id="cert-preview" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 relative z-10">
  
  <div class="reveal card p-6 sm:p-10 text-center max-w-4xl mx-auto flex flex-col items-center group cursor-default relative overflow-hidden" style="--card-glow: rgba(139, 92, 246, 0.4);">
    
    <!-- Inner gradient accent -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-purple/40 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-brand-purple/[0.04] to-transparent pointer-events-none"></div>

    <!-- Label -->
    <div class="mb-6 relative z-10">
      <span class="inline-flex items-center gap-2 rounded-full border border-brand-purple/20 bg-brand-purple/[0.06] px-3 py-1 text-[9px] font-mono font-semibold uppercase tracking-widest text-brand-purple">
        <span class="h-1.5 w-1.5 rounded-full bg-brand-purple animate-pulse"></span>
        Formación Continua
      </span>
    </div>

    <!-- Title -->
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-white mb-3 relative z-10">
      Oracle Next Education
      <span class="block text-gradient mt-1 text-2xl sm:text-3xl font-semibold">& Formación Avanzada</span>
    </h2>
    
    <p class="text-base sm:text-lg text-zinc-400 max-w-xl leading-relaxed mb-8 relative z-10">
      Ruta especializada en Back-End y cloud con un portafolio de 
      <strong class="text-brand-purple font-bold">{certCount}</strong> 
      certificaciones técnicas verificables.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 items-center relative z-10">
      <a href={`${base}/certificados`.replace('//', '/')} class="btn-accent">
        Ver Certificados
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
      </a>
      <a href="https://linkedin.com/in/angelezequiel" target="_blank" rel="noopener noreferrer" class="btn-primary">
        <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        Validar en LinkedIn
      </a>
    </div>

  </div>
</section>

<div class="divider-gradient mx-auto max-w-5xl"></div>
