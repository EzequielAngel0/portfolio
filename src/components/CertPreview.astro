---
// Certificate preview banner for index V4 - Colorful Bento
import certData from '../data/certificados.json';
const certCount = "50+";
const base = import.meta.env.BASE_URL;
---

<section id="cert-preview" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 relative z-10">
  
  <div class="bento-card bento-card-hover p-8 sm:p-16 text-center max-w-5xl mx-auto flex flex-col items-center relative overflow-hidden group" style="--hover-color: rgba(244, 63, 94, 0.4)">
    
    <!-- Big glowing backdrop -->
    <div class="absolute inset-0 bg-gradient-to-br from-brand-rose/10 via-brand-purple/5 to-transparent blur-[80px] pointer-events-none group-hover:opacity-75 transition-opacity"></div>
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-brand-rose/20 rounded-full blur-[100px] pointer-events-none mix-blend-screen group-hover:bg-brand-rose/30 transition-all"></div>

    <!-- Meta tag -->
    <div class="mb-8 relative z-10">
      <span class="inline-flex items-center gap-2 rounded-full border border-brand-rose/30 bg-brand-rose/10 px-4 py-1.5 text-xs font-mono font-bold uppercase tracking-widest text-brand-rose shadow-[0_0_20px_rgba(244,63,94,0.15)]">
        <span class="h-2 w-2 rounded-full bg-brand-rose"></span>
        Validación Técnica Continua
      </span>
    </div>

    <!-- Main Text -->
    <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight text-white mb-6 relative z-10 drop-shadow-xl">
      Oracle Next Education <br class="hidden sm:block" />
      <span class="text-brand-rose opacity-90">& Formación Avanzada</span>
    </h2>
    
    <p class="text-lg sm:text-xl text-zinc-300 max-w-3xl font-medium leading-relaxed mb-12 relative z-10">
      Ruta hiperespecializada en (Back-End) y avance hacia cloud. 
      Actualmente cuento con un portafolio documentado de <strong class="text-white bg-brand-rose/20 px-3 py-1 rounded-md border border-brand-rose/30">{certCount}</strong> cursos e hitos formativos en tecnologías Full Stack.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-5 items-center relative z-10">
      <a
        href={`${base}/certificados`.replace('//', '/')}
        class="inline-flex h-14 min-w-[220px] items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-brand-rose to-brand-purple px-8 font-bold text-white transition-all hover:scale-105 shadow-[0_10px_30px_rgba(244,63,94,0.4)]"
      >
        Galería de Certificados
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
      </a>
      <a
        href="https://linkedin.com/in/angelezequiel"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-glass inline-flex h-14 min-w-[220px] items-center justify-center gap-2 rounded-xl px-8 font-bold text-zinc-200 transition-colors shadow-lg"
      >
        <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        Validar en LinkedIn
      </a>
    </div>

  </div>
</section>
